{
  "name": "senior-law-partner",
  "version": "1.1.0",
  "description": "A local AI legal mentor and study interface for 1L law students.",
  "main": "main.js",
  "author": "Bianna",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "build:win": "vite build && electron-builder --win",
    "build:mac": "vite build && electron-builder --mac",
    "build:pwa": "cross-env BUILD_TARGET=pwa vite build"
  },
  "build": {
    "appId": "com.biannalaw.seniorpartner",
    "productName": "Senior Law Partner",
    "icon": "assets/icon.ico",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "rag.js",
      "renderer.js",
      "dist-react/**/*",
      "assets/**/*",
      "legal-data/**/*",
      "skills/**/*",
      "!**/*.{md,markdown,log,map}",
      "!**/test{s,}/**",
      "!**/__test{s,}__/**",
      "!**/docs/**",
      "!**/example{s,}/**",
      "!**/benchmark{s,}/**",
      "!**/.github/**",
      "!**/coverage/**",
      "!**/*.d.ts",
      "!src/**"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.education",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Senior Law Partner",
      "backgroundColor": "#1a1a2e"
    },
    "publish": {
      "provider": "github",
      "owner": "richardguti",
      "repo": "bianna-law-app",
      "releaseType": "release"
    },
    "protocols": {
      "name": "Senior Law Partner",
      "schemes": [
        "seniorpartner",
        "biannalaw"
      ]
    }
  },
  "keywords": [
    "law",
    "electron",
    "ai",
    "1L"
  ],
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "cross-env": "^7.0.3",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "vite-plugin-pwa": "^1.2.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google/generative-ai": "^0.24.1",
    "@notionhq/client": "^5.14.0",
    "@supabase/supabase-js": "^2.99.3",
    "@tanstack/react-query": "^5.95.0",
    "docx": "^9.6.1",
    "electron-log": "^5.4.3",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.577.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "supermemory": "^4.17.0",
    "youtube-transcript": "^1.3.0",
    "zustand": "^5.0.12"
  }
}
